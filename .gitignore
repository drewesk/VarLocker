# agent rules - not for source control
AGENTS.md

# dependencies
node_modules/
bun.lockb
.bun/

# commit bun.lock for reproducible deploys
!bun.lock

# build output
dist/
vp-out/
.vite/

# env files - never commit secrets
.env
.env.local
.env.*.local
# .env.example is safe to commit (contains no secrets)
!.env.example

# database files
*.db
*.db-shm
*.db-wal
data/

# key material
*.key
*.pem
*.p8
kyber.priv
kyber.pub

# test output
coverage/

# os
.DS_Store
Thumbs.db

# editor
.vscode/settings.json
.idea/

# vite-plus local cache
.vite-plus/

# bun compiled binaries
*.exe
dist/varlocker
dist/cli.js

# local deploy secrets and machine-specific artifacts
deploy/cloud-init*.yaml
deploy/*.env
deploy/*.env.*
deploy/*.enc
deploy/*.local
deploy/*.local.*
deploy/*.secret*
