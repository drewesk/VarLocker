# VarLocker Server Configuration
# Copy this to .env and fill in your values. NEVER commit .env to git.

# REQUIRED: Master password used to derive the encryption key for secrets at rest.
# Use something long, random, and memorable. Treat it like a root password.
# Example: MASTER_PASSWORD=MySecurePassword123!WithSpecialChars
MASTER_PASSWORD=

# OPTIONAL: Port the server listens on (default: 3000)
PORT=3000

# OPTIONAL: Admin token created automatically on startup.
# If set, this token can access all projects without needing to create one via the UI.
# Generate a random string: openssl rand -hex 32
# ADMIN_TOKEN=your-random-token-here

# OPTIONAL: Directory for database and keypair files (default: ./data)
# DATA_DIR=./data
