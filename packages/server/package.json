{
  "name": "@varlocker/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build:ui": "vp build --outDir dist/ui",
    "build:server": "bun build src/index.ts --compile --outfile dist/varlocker",
    "build": "bun run build:ui && bun run build:server",
    "start": "dist/varlocker"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.6.0",
    "hono": "^4.12.10"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0",
    "vite": "^8.0.3",
    "vite-plus": "^0.1.15"
  }
}
