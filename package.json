{
  "name": "varlocker",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/server",
    "packages/cli"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/server dev",
    "build": "bun run --cwd packages/server build",
    "start": "bun run --cwd packages/server start",
    "cli:build": "bun run --cwd packages/cli build"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
